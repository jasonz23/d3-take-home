# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# OS and editor files
.DS_Store
Thumbs.db
.idea/
.vscode/
.vs/
*.swp
*.swo

# Local secrets and environment overrides
.env
.env.*
!.env.example
!*.env.example
!frontend/.env.local.example
**/appsettings.Development.json
**/secrets.json
*.pem
*.key

# Node dependencies and package-manager caches
node_modules/
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output
.next/
**/.next/
out/
**/out/

# Frontend test and coverage output
coverage/
**/coverage/
test-results/
**/test-results/
playwright-report/
**/playwright-report/

# Generic build output
build/
**/build/
dist/
**/dist/

# Logs and debug output
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# TypeScript incremental build info
*.tsbuildinfo

# .NET build and local tooling output
bin/
obj/
**/bin/
**/obj/
TestResults/
**/TestResults/
*.user
*.rsuser
*.suo
*.userosscache
*.sln.docstates
*.nupkg
*.snupkg

# Local database files
*.db
*.sqlite
*.sqlite3

# Deployment/cache folders
.vercel/
